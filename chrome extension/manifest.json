{
  "manifest_version": 3,
  "name": "Steam App Checker",
  "version": "1.0",
  "description": "Checks Steam game information",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:7123/*",
    "https://store.steampowered.com/*"
  ],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}